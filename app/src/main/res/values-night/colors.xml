<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>

    <!-- Monotone Classic Dark Palette (Obsidian & Steel) -->
    <color name="primaryColor">#000000</color> <!-- Deepest Obsidian -->
    <color name="primaryDark">#000000</color>
    <color name="accentColor">#9E9E9E</color> <!-- Lighter Slate -->
    <color name="backgroundColor">#121212</color> <!-- Soothing Dark Surface -->
    <color name="surfaceColor">#1C1C1E</color> <!-- Slightly elevated surface -->

    <!-- Beta Accent Color -->
    <color name="brandAccent">#E5C100</color> <!-- Enhanced Gold -->

    <color name="textPrimary">#E0E0E0</color>
    <color name="textSecondary">#9E9E9E</color>
    <color name="childCardBackground">#2C2C2E</color>

    <!-- Component Colors -->
    <color name="navBackground">@color/surfaceColor</color>
    <color name="drawerHeaderBackground">@color/toolbarColor</color>
    <color name="navItemColor">@color/accentColor</color>
    <color name="dropdownBackground">@color/surfaceColor</color>
    <color name="dropdownText">@color/textPrimary</color>
    <color name="toolbarColor">@color/primaryColor</color>
    <color name="toolbarTextColor">@color/white</color>
    <color name="toolbarComponentBg">#22FFFFFF</color> <!-- Subtle white highlight in dark mode -->
    <color name="toolbarComponentStroke">#1AFFFFFF</color>

    <color name="dividerColor">#40FFFFFF</color> <!-- Lighter/Visible border for Dark Theme -->
    <color name="toggleSelectedBackground">@color/brandAccent</color>
    <color name="toggleSelectedIcon">@color/black</color>
    <color name="toggleUnselectedIcon">@color/brandAccent</color>
    <color name="sectionBgSubtle">#12FFFFFF</color> <!-- Subtle light tint for Dark Theme -->
    <color name="sectionBgWarmer">#1AEE9B00</color> <!-- Subtle warm/amber glow for Dark Theme -->
    <color name="sectionBgAlert">#1AFF0000</color> <!-- Subtle reddish glow for Dark Theme -->
    <color name="sectionBgTeal">#1A009688</color> <!-- Subtle teal glow for Dark Theme -->
</resources>
