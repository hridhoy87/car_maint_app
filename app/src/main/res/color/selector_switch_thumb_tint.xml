<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Transparent for BDT state (checked) to show full coin -->
    <item android:alpha="0.0" android:color="@android:color/white" android:state_checked="true" />
    <!-- White for Litre state (unchecked) to show the knob -->
    <item android:color="@color/white" />
</selector>