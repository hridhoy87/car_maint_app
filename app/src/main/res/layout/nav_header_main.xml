<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:background="@color/drawerHeaderBackground"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="24dp"
    android:theme="@style/ThemeOverlay.App.Toolbar">

    <FrameLayout
        android:id="@+id/drawer_car_profile_container"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_car_profile">

        <TextView
            android:id="@+id/drawer_car_initial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="-"
            android:textColor="@color/black"
            android:textSize="28sp"
            android:textStyle="bold"
            android:includeFontPadding="false" />
    </FrameLayout>

    <TextView
        android:id="@+id/drawer_car_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="16dp"
        android:text="@string/car"
        android:textColor="@color/toolbarTextColor"
        android:letterSpacing="0.1"
        android:textSize="16sp"
        android:textStyle="bold"
        android:includeFontPadding="false" />

    <TextView
        android:id="@+id/drawer_car_reg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:textColor="@color/toolbarTextColor"
        android:alpha="0.7"
        android:textSize="12sp"
        android:includeFontPadding="false" />

    <TextView
        android:id="@+id/drawer_car_odo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_odo_highlight"
        android:text="@string/odo_format"
        android:textColor="@color/toolbarTextColor"
        android:alpha="0.8"
        android:textSize="12sp"
        android:letterSpacing="0.05"
        android:includeFontPadding="false" />

</LinearLayout>
