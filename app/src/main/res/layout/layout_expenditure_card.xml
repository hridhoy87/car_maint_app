<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="24dp">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/timeline_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.07" />

    <View
        android:id="@+id/sphere"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/ic_sphere"
        app:layout_constraintEnd_toEndOf="@id/timeline_guideline"
        app:layout_constraintStart_toStartOf="@id/timeline_guideline"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/card_pointer"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:background="@drawable/ic_pointer"
        app:layout_constraintBottom_toBottomOf="@id/sphere"
        app:layout_constraintStart_toEndOf="@id/sphere"
        app:layout_constraintTop_toTopOf="@id/sphere" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="-4dp"
        android:layout_marginEnd="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/surfaceColor"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="@id/sphere"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/card_pointer"
        app:layout_constraintTop_toTopOf="@id/sphere">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/text_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/textSecondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/text_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/text_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/brandAccent"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>